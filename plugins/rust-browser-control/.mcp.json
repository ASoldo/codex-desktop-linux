{
  "mcpServers": {
    "rust-browser-control": {
      "command": "bash",
      "args": ["./scripts/rust-browser-control-mcp"],
      "cwd": ".",
      "env_vars": [
        "CODEX_THREAD_ID",
        "CODEX_TURN_ID",
        "RUST_BROWSER_SESSION_ID",
        "RUST_BROWSER_TURN_ID",
        "RUST_BROWSER_SOCKET_DIR",
        "RUST_BROWSER_SESSIONS_ROOT",
        "RUST_BROWSER_DOWNLOAD_DIR",
        "RUST_BROWSER_ALLOWED_HOSTS"
      ],
      "tool_timeout_sec": 120
    }
  }
}
